{
	"name": "mobile-tts-yds",
	"build": {
		"dockerfile": "../Dockerfile.dev",
		"context": ".."
	},
	"features": {
		"ghcr.io/devcontainers/features/git:1": {}
	},
	"workspaceFolder": "/app",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"charliermarsh.ruff",
				"ms-toolsai.jupyter",
				"ms-pyright.pyright"
			],
			"settings": {
				"python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python"
			}
		}
	},
	"remoteEnv": {
		"PYTHONPATH": "${containerWorkspaceFolder}"
	},
	"mounts": [
		"source=${localWorkspaceFolder},target=/app,type=bind"
	],
	"postCreateCommand": "cd ${containerWorkspaceFolder} && uv sync --dev",
	"runArgs": [
		"--gpus",
		"all",
		"--cpus=2.0",
		"--memory=4g",
		"--memory-reservation=2g"
	]
}
